ProCVdata <- ProCVdata |>
mutate(datetime= make_datetime(Year, Month, Day, Hour, Minute, Second))
#make sure your data is in the time format
str(ProCVdata$datetime)
#check what timezone is assigned to your data
attr(ProCVdata$datetime, "tzone")
#want to switch my data to halifax time, will create a new column
ProCVdata <- ProCVdata %>%
mutate(datetime_halifax = with_tz(datetime, tzone = "America/Halifax"))
#for some reason the co2 column isnt numeric, wont let me run my next line of code without changing
ProCVdata$CO2 <- as.numeric(ProCVdata$CO2)
#need to add column for the calculated pc02
ProCVdata <- ProCVdata %>%
mutate(pCO2 = CO2*Cell.gas.pressure / 1013.25)
