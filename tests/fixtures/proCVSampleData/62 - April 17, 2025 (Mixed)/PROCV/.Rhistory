ProCVdata <- read.csv("C:\\Users\\em316047\\OneDrive - Dalhousie University\\(Elec_Ocean Eng) Aaron MacNeill's files - Bedford Basin Planetary\\Data\\67 - June 26 2025 (Monthly)\\Pro-CV\\processed\\procv_june26.csv")
ProCVdata <- ProCVdata |>
mutate(datetime= make_datetime(Year, Month, Day, Hour, Minute, Second))
#make sure your data is in the time format
str(ProCVdata$datetime)
#check what timezone is assigned to your data
attr(ProCVdata$datetime, "tzone")
#want to switch my data to halifax time, will create a new column
ProCVdata <- ProCVdata %>%
mutate(datetime_halifax = with_tz(datetime, tzone = "America/Halifax"))
#for some reason the co2 column isnt numeric, wont let me run my next line of code without changing
ProCVdata$CO2 <- as.numeric(ProCVdata$CO2)
#need to add column for the calculated pc02
ProCVdata <- ProCVdata %>%
mutate(pCO2 = CO2*Cell.gas.pressure / 1013.25)
site_list <- split(ProCVdata, ProCVdata$fileName)
View(site_list)
#go through the rest of this scriptbefore running
#make sure these names match the file name exact
McNabs <- site_list$`7_McNabs`
View(site_list)
#carbon buoy is narrows/armament buoy
site_list <- split(ProCVdata, ProCVdata$fileName)
#go through the rest of this scriptbefore running
#make sure these names match the file name exact
McNabs <- site_list$`7_McNabs`
View(ProCVdata)
#go through the rest of this scriptbefore running
#make sure these names match the file name exact
#no data in mcnabs file
#McNabs <- site_list$`7_McNabs`
Armament <- site_list$`1_CarbonBuoy`
TuftsCove <- site_list$`2_Tufts`
MacKay <- site_list$`3_MacKay`
DRDC <- site_list$`4_DRDC`
Sackville <- site_list$`6_Sackville`
Compass <- site_list$`5_Compass`
tailend <- bind_rows(
# McNabs     %>% slice_tail(n = 50) %>% mutate(Site = "McNabs"),
TuftsCove  %>% slice_tail(n = 50) %>% mutate(Site = "TuftsCove"),
MacKay     %>% slice_tail(n = 50) %>% mutate(Site = "MacKay"),
Sackville  %>% slice_tail(n = 50) %>% mutate(Site = "Sackville"),
Compass    %>% slice_tail(n = 50) %>% mutate(Site = "Compass"),
Armament   %>% slice_tail(n = 50) %>% mutate(Site = "Armament"),
DRDC       %>% slice_tail(n = 50) %>% mutate(Site = "DRDC")
)
summary_stats <- tailend %>%
group_by(fileName) %>%
summarise(
mean_pCO2 = mean(pCO2, na.rm = TRUE),
sd_pCO2 = sd(pCO2, na.rm = TRUE)
)
View(tailend)
View(summary_stats)
#remove mcnabs: "1_McNabs"            = "#e7298a",
station_cols <- c(
"5_Compass"           = "#355E3B",
"4_DRDC"              = "#d95f02",
"3_MacKay"            = "#800080",
"6_Sackville"   = "#66a61e",
"2_Tufts"        = "#e6ab02",
"1_CarbonBuoy" = "#000080"
)
ggplot(summary_stats, aes(x = fileName, y = mean_pCO2, color=fileName)) +
geom_point(size = 3, na.rm = TRUE) +
geom_errorbar(aes(ymin = mean_pCO2 - sd_pCO2, ymax = mean_pCO2 + sd_pCO2), width = 0.2, na.rm = TRUE) +
scale_x_discrete(labels = c(
"2_Tufts" = "Tufts Cove",
"3_MacKay" = "MacKay",
"4_DRDC" = "DRDC",
"6_Sackville" = "Sackville River",
"5_Compass" = "Compass",
"1_CarbonBuoy" = "Armament"
)) +
geom_text(aes(label = round(mean_pCO2, 1)), vjust = -1.0, hjust= 1.2, size = 3.5, fontface="bold", na.rm = TRUE) +
scale_color_manual(values = station_cols) +
labs(title = expression("Average Surface (0.5m) pCO"[2]*" Across Sampling Stations, June 26, 2025."),
x = "Station",
y = expression("pCO"[2] * " (µatm)"),
caption = expression("Average pCO"[2]*" values calculated from the last 50 observations (n=50), across sampling stations.")
) +
theme_gray() +
theme(legend.position = "none")
#doublecheck this before saving
ggsave("C:\\Users\\em316047\\OneDrive - Dalhousie University\\(Elec_Ocean Eng) Aaron MacNeill's files - Bedford Basin Planetary\\Data\\67 - June 26 2025 (Monthly)\\Pro-CV\processed\\procvplot_june26.png", width = 7, units="in", dpi=300)
#doublecheck this before saving
ggsave("C:\\Users\\em316047\\OneDrive - Dalhousie University\\(Elec_Ocean Eng) Aaron MacNeill's files - Bedford Basin Planetary\\Data\\67 - June 26 2025 (Monthly)\\Pro-CV\\processed\\procvplot_june26.png", width = 7, units="in", dpi=300)
write.csv(summary_stats, "C:\\Users\\em316047\\OneDrive - Dalhousie University\\(Elec_Ocean Eng) Aaron MacNeill's files - Bedford Basin Planetary\\Data\\67 - June 26 2025 (Monthly)\\Pro-CV\processed\\pCO2_summary_statsJune26.csv", row.names = FALSE)
